# NexTask — Variables de Entorno
# Copia este archivo a .env y completa los valores

# ===========================
# Google AI
# ===========================
GEMINI_API_KEY=tu_api_key_aqui
GEMINI_MODEL=gemini-2.5-flash

# ===========================
# Telegram
# ===========================
TELEGRAM_BOT_TOKEN=tu_bot_token_aqui

# ===========================
# Supabase
# ===========================
SUPABASE_URL=tu_supabase_url
SUPABASE_KEY=tu_supabase_key

# ===========================
# Notion
# ===========================
NOTION_API_KEY=tu_notion_api_key
NOTION_DB_TAREAS=tu_db_id
NOTION_DB_HALLAZGOS=tu_db_id
NOTION_DB_CONFIG=tu_db_id
NOTION_DB_AGENDA=tu_db_id

# ===========================
# Google Calendar (OAuth2)
# ===========================
GCAL_CALENDAR_ID=tu_correo@gmail.com
# GCAL_CREDENTIALS_FILE=credentials.json  (para OAuth local)
# GCAL_TOKEN_FILE=token.json

# ===========================
# Redis / Sesión
# ===========================
REDIS_URL=redis://localhost:6379
SESSION_TTL_SECONDS=86400

# ===========================
# App Config
# ===========================
APP_ENV=development  # development | production
LOG_LEVEL=INFO
